# Application
APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:your-base64-key
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://127.0.0.1:3000

# SPA auth: comma-separated frontend origins that receive session (HttpOnly) cookies
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,127.0.0.1:8000,::1
# CORS: comma-separated allowed origins. In production use exact SPA URL(s); never use *
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://kechow-frontend.onrender.com

# Delivery: driver earnings. driver_commission_rate 0-1 (e.g. 0.15 = 15% of order total). delivery_fee_fixed = extra amount per delivery.
DELIVERY_DRIVER_COMMISSION_RATE=1.0
DELIVERY_FEE_FIXED=0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# In production use: LOG_STACK=daily,error,delivery for separate channels
LOG_STACK=single
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional: Error tracking (when Sentry is enabled)
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: Telescope (dev only; set TELESCOPE_ENABLED=false in production)
# TELESCOPE_ENABLED=true

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
DB_DATABASE=kechow
DB_USERNAME=root
DB_PASSWORD=root
